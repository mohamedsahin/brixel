# ─── Database ───────────────────────────────────────────────
# Postgres connection string (Neon, Supabase, Vercel Postgres, local…)
DATABASE_URL="postgresql://user:password@localhost:5432/brixel?schema=public"

# ─── Pexels (cover images for blog articles — free API) ─────
# Sign up free at https://www.pexels.com/api/ — no credit card needed
PEXELS_API_KEY=""

# ─── Groq (AI concierge — free tier) ────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# ─── Email (Resend, transactional) ──────────────────────────
RESEND_API_KEY="re_..."
# Where new-lead / hot-lead notifications are sent:
OWNER_EMAIL="owner@brixel.ae"
# Verified "from" address on your Resend domain:
EMAIL_FROM="Brixel <hello@brixel.ae>"

# ─── Business contact details (shown in UI + links) ─────────
NEXT_PUBLIC_PHONE="+971 50 123 4567"
NEXT_PUBLIC_PHONE_RAW="+971501234567"
NEXT_PUBLIC_WHATSAPP="971501234567"
NEXT_PUBLIC_EMAIL="hello@brixel.ae"

# ─── Admin access (DEMO gate) ───────────────────────────────
# Replace this lightweight gate with Clerk or NextAuth for production.
ADMIN_PASSWORD="change-me"

# ─── Phase 3 cron (batch insights) ──────────────────────────
CRON_SECRET="set-a-long-random-string"
